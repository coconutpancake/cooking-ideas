# MiMo API configuration
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.xiaomimimo.com/v1
VISION_MODEL_NAME=mimo-v2.5
TEXT_MODEL_NAME=mimo-v2.5
DETAIL_MODEL_NAME=mimo-v2.5
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,https://your-web-domain.com,https://your-expo-domain.expo.app

# API security
# Production defaults to requiring Authorization: Bearer <token>.
# Use API_CLIENT_TOKEN for the current MVP app gate, or SUPABASE_JWT_SECRET when Supabase Auth is introduced.
API_AUTH_REQUIRED=true
API_CLIENT_TOKEN=replace_with_a_long_random_token
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWT_ISSUER=
